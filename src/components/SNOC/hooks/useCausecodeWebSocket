// src/hooks/useCausecodeWebSocket.js
import { useEffect, useRef } from "react";
import { useDispatch } from "react-redux";
import { wsMergeKpiPoints } from "../redux/KPI/kpiSlice";

// Đường WS causecode

const BASE_WS_URL =
  process.env.REACT_APP_SNOC_WS_URL || "ws://localhost:8000/ws";

// const WS_URL = "ws://10.155.43.201:8000/ws/causecode/";
const WS_URL = `${BASE_WS_URL}/causecode/`;
const RECONNECT_INTERVAL = 5000;

/**
 * Hook nhận realtime cause-code KPI và merge vào store.
 * Chỉ merge khi khớp filter hiện tại (platform/devices/kpis) và
 * khi đã có ít nhất 1 KPI được chọn.
 */
export default function useCausecodeWebSocket({
  selectedPlatform,
  selectedDevices,
  selectedKPIs,
} = {}) {
  const dispatch = useDispatch();

  const socketRef = useRef(null);
  const timerRef = useRef(null);
  const closedRef = useRef(false);

  // ====== Filter refs (tránh stale-closure) ======
  const platRef = useRef(selectedPlatform || "");
  const devSetRef = useRef(
    new Set(
      (selectedDevices || [])
        .map((d) => (typeof d === "string" ? d : d?.value))
        .filter(Boolean)
    )
  );
  const kpiSetRef = useRef(
    new Set(
      (selectedKPIs || [])
        .map((k) => (typeof k === "string" ? k : k?.value))
        .filter(Boolean)
    )
  );

  // Cập nhật refs mỗi khi props đổi
  useEffect(() => {
    platRef.current = selectedPlatform || "";
  }, [selectedPlatform]);

  useEffect(() => {
    devSetRef.current = new Set(
      (selectedDevices || [])
        .map((d) => (typeof d === "string" ? d : d?.value))
        .filter(Boolean)
    );
  }, [selectedDevices]);

  useEffect(() => {
    kpiSetRef.current = new Set(
      (selectedKPIs || [])
        .map((k) => (typeof k === "string" ? k : k?.value))
        .filter(Boolean)
    );
  }, [selectedKPIs]);

  useEffect(() => {
    closedRef.current = false;

    const connect = () => {
      if (closedRef.current) return;
      const ws = new WebSocket(WS_URL);
      socketRef.current = ws;

      ws.onopen = () => {
        if (process.env.NODE_ENV !== "production") {
          console.log("✅ CauseCode WS connected");
        }
      };

      ws.onmessage = (ev) => {
        try {
          const data = JSON.parse(ev.data);

          // Chỉ xử lý gói điểm KPI realtime từ causecode
          if (
            data?.type !== "causecode_chart_points" ||
            !Array.isArray(data?.points)
          ) {
            return;
          }

          const msgPlatform = data.platform || "";
          const curPlatform = platRef.current;
          const curDevSet = devSetRef.current;
          const curKpiSet = kpiSetRef.current;

          // Bắt buộc phải có ít nhất 1 KPI đang chọn
          if (curKpiSet.size === 0) {
            if (process.env.NODE_ENV !== "production") {
              console.log("[WS CauseCode] skip merge: no KPI selected");
            }
            return;
          }

          // Lọc sớm theo platform (nếu UI đã chọn platform)
          if (curPlatform && msgPlatform && curPlatform !== msgPlatform) {
            if (process.env.NODE_ENV !== "production") {
              console.log("[WS CauseCode] skip: platform mismatch", {
                ui: curPlatform,
                ws: msgPlatform,
              });
            }
            return;
          }

          // Chuẩn hoá & lọc theo devices/KPIs
          const normalized = data.points
            .map((p) => {
              const ts = Date.parse(p?.timestamp); // ISO -> epoch(ms)
              const v = Number(p?.value);
              return {
                device: p?.device,
                platform: p?.platform || msgPlatform || curPlatform || "",
                kpi: p?.kpi,
                value: Number.isFinite(v) ? v : null,
                timestamp: p?.timestamp || null, // ISO
                created_at: p?.created_at || null, // ISO
                ts: Number.isFinite(ts) ? ts : null,
              };
            })
            .filter((p) => {
              if (
                !p.device ||
                !p.kpi ||
                !Number.isFinite(p.value) ||
                !Number.isFinite(p.ts)
              ) {
                return false;
              }
              // device filter (nếu đã chọn)
              if (curDevSet.size > 0 && !curDevSet.has(p.device)) return false;
              // kpi filter (bắt buộc)
              if (!curKpiSet.has(p.kpi)) return false;
              return true;
            });

          if (normalized.length === 0) {
            if (process.env.NODE_ENV !== "production") {
              console.log("[WS CauseCode] no points matched current filter");
            }
            return;
          }

          if (process.env.NODE_ENV !== "production") {
            const sample = normalized[0];
            console.log("[WS CauseCode] merge:", {
              count: normalized.length,
              platform: msgPlatform || curPlatform,
              filter: {
                platform: curPlatform,
                devices: Array.from(curDevSet),
                kpis: Array.from(curKpiSet),
              },
              sample: {
                device: sample.device,
                kpi: sample.kpi,
                timestamp: sample.timestamp,
                utc_from_timestamp: sample.timestamp
                  ? new Date(sample.timestamp).toISOString()
                  : null,
                value: sample.value,
              },
            });
          }

          // Merge vào store (slice sẽ dedup/sort theo phút)
          dispatch(
            wsMergeKpiPoints({
              platform: msgPlatform || curPlatform,
              points: normalized,
              // filter để debug/trace nếu cần ở reducer (không bắt buộc)
              filter: {
                platform: curPlatform,
                devices: Array.from(curDevSet),
                kpis: Array.from(curKpiSet),
              },
            })
          );
        } catch (e) {
          console.error("WS parse error:", e);
        }
      };

      ws.onclose = () => {
        if (closedRef.current) return;
        console.warn("⚠️ CauseCode WS closed — reconnecting...");
        timerRef.current = setTimeout(connect, RECONNECT_INTERVAL);
      };

      ws.onerror = () => {
        try {
          ws.close();
        } catch (_) {}
      };
    };

    connect();

    return () => {
      closedRef.current = true;
      if (timerRef.current) clearTimeout(timerRef.current);
      try {
        socketRef.current?.close();
      } catch (_) {}
    };
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [dispatch]); // tạo kết nối 1 lần; filter dùng qua refs nên không cần deps

  return null;
}
