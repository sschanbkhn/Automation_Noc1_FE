{
  "compilerOptions": {
    "outDir": "./dist/",
    "rootDir": "./src",
    "noImplicitAny": true,
    "allowSyntheticDefaultImports": true,
    "module": "es6",
    "target": "es5",
    "ignoreDeprecations": "6.0",
    "jsx": "react",
    "allowJs": true,
    "moduleResolution": "node",
    "baseUrl": "./src",
    "resolveJsonModule": true,
    "paths": {
      "app/*": [
        "app/*"
      ],
      "store/*": [
        "store/*"
      ],
      "assets/*": [
        "assets/*"
      ],
      "components/*": [
        "components/*"
      ],
      "helpers/*": [
        "helpers/*"
      ],
      "routes/*": [
        "routes/*"
      ],
      "services/*": [
        "services/*"
      ],
      "models/*": [
        "models/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "src",
    "index.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.backup",
    "**/*.bak",
    "**/Luu Tru/**/*",
    "**/backup/**/*",
    "**/old/**/*",
    "**/*_backup.*",
    "**/*_old.*",
    "src/components/RNOC1/R005-SleepingCell/Designer/R005Tabs_9.tsx",
    "src/components/RNOC1/R005-SleepingCell/Designer/R005Tabs_7.tsx"
  ]
}